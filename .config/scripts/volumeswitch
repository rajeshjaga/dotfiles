#/bin/bash

#pactl list short sink-inputs | cut -f1 | while read stream; do pactl move-sink-input $stream [sink_name]; done

selected_op=$(printf "Headphone\nSpeakers" | dmenu -fn "monospace-12" -h 25 -p "Audio Output" -l 2 -bw 2 | xargs echo)

speaker(){
     pactl set-default-sink alsa_output.pci-0000_00_1f.3-platform-skl_hda_dsp_generic.HiFi__Speaker__sink
    notify-send --icon=speaker "DefaultSink switched to speaker or $(pactl get-default-sink)" --expire-time=700
}

headphone(){
    pactl set-default-sink alsa_output.usb-Synaptics_VENTURE-DAS-32-00.analog-stereo
    notify-send --icon=headphone "DefaultSink switched to headphone or $(pactl get-default-sink)" --expire-time=700
}

case $selected_op in
    "Headphone")
        headphone
        ;;
    "Speakers")
        speaker
        ;;
    *)
        $(notify-send "You shouldn't have reached here")
        ;;
esac

