set $sway_config "$HOME/.config/sway"
include $sway_config/keybinds.conf
include $sway_config/devices.conf
include $sway_config/windows.conf
include $sway_config/workspace.conf
include $sway_config/media.conf
include $sway_config/autostart.conf



### Idle configuration
exec swayidle -w \
         timeout 300 'swaylock -f -c 000000' \
         timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
         before-sleep 'swaylock -f -c 000000'


