{
    "layer": "top", 
        "position": "top", 
        "height": 34, 
        //"width": , 
        "spacing": 4, 
        "modules-left": ["hyprland/workspaces"],
        //"modules-center": ["hyprland/window"],
        "modules-right": ["keyboard-state", "pulseaudio", "network", "memory", "backlight", "battery", "clock", "tray"],

        "keyboard-state": {
            "numlock": true,
            "capslock": true,
            "format": "{name} {icon}",
            "format-icons": {
                "locked": "яАг",
                "unlocked": "яВЬ"
            }
        },
        "tray": {
            // "icon-size": 21,
            "spacing": 10
        },
        "clock": {
            // "timezone": "Aisa/Kolkata",
            "format": "яАЧ {:%H:%M}",
            "format-alt": "{:%Y-%m-%d}"
        },
        "cpu": {
            "format": "{usage}% яЛЫ",
            "tooltip": false
        },
        "memory": {
            "format": "яФ╕ {}% "
        },
        "temperature": {
            // "thermal-zone": 2,
            // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
            "critical-threshold": 80,
            // "format-critical": "{temperatureC}┬░C {icon}",
            "format": "{temperatureC}┬░C {icon}",
            "format-icons": ["яЭл", "яЛЙ", "яЭй"]
        },
        "backlight": {
            // "device": "acpi_video1",
            "format": "{icon} {percent}%",
            "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"]
        //    "on-scroll-up": "$HOME/dotfiles/.config/scripts/brightness up",
         //   "on-scroll-down": "$HOME/dotfiles/.config/scripts/brightness dow:"
        },
        "battery": {
            "states": {
                "good": 50,
                "warning": 30,
                "critical": 15
            },
            "format": "{icon} {capacity}%",
            "format-charging": "юХЫ {capacity}%",
            "format-plugged": "юХЭ {capacity}%",
            "format-alt": "{icon} {time}",
            // "format-good": "", // An empty format will hide the module
            // "format-full": "",
            "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
        },
        "network": {
            // "interface": "wlp2*", // (Optional) To force the use of this interface
            "format-wifi": "яЗл {essid}",
            "format-ethernet": "{ipaddr}/{cidr} яЮЦ",
            "tooltip-format": "{ifname} via {gwaddr} яЮЦ",
            "format-linked": "{ifname} (No IP) яЮЦ",
            "format-disconnected": "Disconnected тЪа",
            "format-alt": "{ifname}: {ipaddr}/{cidr}"
        },
        "pulseaudio": {
            // "scroll-step": 1, // %, can be a float
            "format": "{volume}% {icon} {format_source}",
            "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
            "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
            "format-muted": "яЪй {format_source}",
            "format-source": "{volume}% яД░",
            "format-source-muted": "яД▒",
            "format-icons": {
                "headphone": "яАе",
                "hands-free": "яЦР",
                "headset": "яЦР",
                "phone": "яВХ",
                "portable": "яВХ",
                "car": "яЖ╣",
                "default": ["яАж", "яАз", "яАи"]
            },
            "on-click": "pavucontrol"
        },
}
