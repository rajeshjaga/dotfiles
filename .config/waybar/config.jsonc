{
  "layer": "top", // Waybar at top layer
  // "width": 1280, // Waybar width 
  "position": "top",
  "height": 20, 
  "spacing": 4,
  "modules-left": [
      "custom/menu",
    "hyprland/workspaces",
  ],
  "modules-center": [
      "hyprland/window"
  ],
  "modules-right": [
    "memory",
    "temperature",
    "backlight",
    "pulseaudio",
    "battery",
    "clock",
    "tray",
    "custom/power"
  ],
  "include":[
      "~/.config/waybar/modules.json"
  ]
}
