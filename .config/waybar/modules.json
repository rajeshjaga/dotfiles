{
    "niri/workspaces": {
        "format": "{value}",
    },
    "niri/window": {
        "format": "{}",
        "max-length": 30,
        "separate-outputs": true
    },
    "tray": {
        "spacing": 10,
    },
    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-full": "{icon} {capacity}%",
        "format-charging": "ΎΚΑ  {capacity}%",
        "format-plugged": "ΎΘο {capacity}%",
        "format-alt": "{time} {icon}",
        "format-icons": ["ΎΚΕ ", "ΎΚΔ ", "ΎΚΓ ", "ΎΚΒ ", "ΎΚΑ "]
    },
    "network": {
        "format-wifi": "ΎΘτ  {essid}({signalStrength}%)",
        "format-ethernet": "≤░ΙΒ {ipaddr}/{cidr}",
        "tooltip-format": "≤░ΙΒ {ifname} via {gwaddr}",
        "format-linked": "≤░ΙΓ {ifname} (No IP)",
        "format-disconnected": "≤░ΙΓ Disconnected",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "kitty -e nmtui"
    },
    "pulseaudio": {
        "format": "{icon} {volume}% {format_source}",
        "format-bluetooth": "ΎΛΦ {volume}% {icon} {format_source}",
        "format-bluetooth-muted": "ΎΛΦ {icon} {format_source}",
        "format-muted": " {format_source}",
        "format-source": " ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ▒ ",
        "format-icons": {
            "headphone": "ΎΑξ ",
            "default": ["ΎΑο", "ΎΑπ ", "ΎΑρ "]
        },
        "on-click": "pavucontrol"
    },
}
